FROM node:22-alpine@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2 AS builder

RUN corepack enable && corepack prepare pnpm@10.23.0 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/schema/package.json ./packages/schema/
COPY packages/schema/tsconfig.json ./packages/schema/
COPY apps/api/package.json ./apps/api/

RUN pnpm install --frozen-lockfile

COPY packages/ ./packages/
COPY apps/api/ ./apps/api/
COPY tsconfig.base.json ./

RUN pnpm --filter @boppl/schema build && pnpm --filter @boppl/api build

# Runner must be glibc-based (Debian), NOT alpine: the pdf-generation worker launches Playwright
# Chromium, and Playwright's Chromium build requires glibc + apt-installable system libs. On alpine
# the browser can't launch, so initBrowserPool() throws and the pdf worker disables itself — every
# PDF export then times out. bookworm-slim + `playwright install --with-deps chromium` fixes that.
FROM node:22-bookworm-slim@sha256:813a7480f28fdadac1f7f5c824bcdad435b5bc1322a5968bbbdef8d058f9dff4 AS runner

RUN corepack enable && corepack prepare pnpm@10.23.0 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/schema/package.json ./packages/schema/
COPY packages/schema/tsconfig.json ./packages/schema/
COPY apps/api/package.json ./apps/api/

RUN pnpm install --frozen-lockfile --prod

# Install the actual Chromium browser binary + its OS dependencies (libnss3, fonts, …). Without this
# the `playwright` npm package resolves but has no browser to launch. Pinned to the apps/api
# playwright version via `pnpm exec`. `--with-deps` shells out to apt and MUST run as root.
# Install into a shared, world-readable path (not /root/.cache) so the unprivileged runtime user
# can locate the browser too.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN cd apps/api && pnpm exec playwright install --with-deps chromium \
  && chmod -R a+rX /ms-playwright

COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/packages/shared ./packages/shared
COPY --from=builder /app/packages/schema/dist ./packages/schema/dist
# Email HTML templates (inliner reads dist/emails/html/*.html at runtime)
COPY apps/api/src/emails/html ./apps/api/dist/emails/html

# Drop to the image's built-in unprivileged `node` user (uid 1000). Chromium runs fine
# non-root inside the container's default seccomp profile. /app and the browser cache
# are handed to `node`; chromium also needs a writable HOME for its singleton profile.
RUN chown -R node:node /app /ms-playwright
USER node
ENV HOME=/home/node

ENV NODE_ENV=production

CMD ["node", "apps/api/dist/workers/server.js"]
